{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/server.js"
    },
    {
      "source": "/((?!api).*\\.(?:js|css|png|jpg|jpeg|svg|gif|ico|json|txt))",
      "destination": "/client/$1"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/client/index.html"
    }
  ]
}

{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/server/server.js"
    },
    {
      "source": "/assets/:path*",
      "destination": "/client/assets/:path*"
    },
    {
      "source": "/(?<file>.*\\.(?:js|css|png|jpg|jpeg|svg|gif|ico|json|txt))",
      "destination": "/client/:file"
    },
    {
      "source": "/(.*)",
      "destination": "/client/index.html"
    }
  ]
}
